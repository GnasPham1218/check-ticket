{
  "name": "check-ticket",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node --watch --experimental-strip-types server/index.ts",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node --experimental-strip-types server/index.ts",
    "typecheck": "tsc --noEmit",
    "seed:demo": "node --experimental-strip-types server/scripts/seedDemo.ts",
    "seed:clear": "node --experimental-strip-types server/scripts/clearDemo.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.22.3",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
